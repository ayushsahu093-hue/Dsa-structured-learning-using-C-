// write a program to print * in sqaure in proper indentation 
# include <iostream>
using namespace std;
int main(){
    int i , n ;
   
    cout<<"enter your number = "<<endl; // take input n or number as input 
    cin>>n;
    for (int i = 1 ; i<=n; i++){ // outer loops is use to for number of line 
        for( int j = 1 ; j<=n ; j++){ // inner loops is make sure that what to print in rows 
            cout<<"*";
        }
    cout<<endl; // this use for new line if we cant use this everything print in one one which looks messy 
    }
    
}


