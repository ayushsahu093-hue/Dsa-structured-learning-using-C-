// Write a program to print charcter in sqaure patterns 
# include <iostream>
using namespace std;
int main(){
    int n ;
    cout<<"Enter your number :"<<endl;
    cin>>n;
    for(int i = 0 ; i<n ; i++){ // outer loops 
        char ch = 'A';
        for (int j = 0 ; j<n ; j++){
            cout<<ch<<" ";
            ch = ch + 1 ;
        }
        cout<<endl;
    }
    return 0;
}
